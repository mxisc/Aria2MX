{
  "name": "aria2mx",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "prepare:aria2": "node scripts/prepare-aria2-runtime.mjs",
    "prepare:aria2:all": "node scripts/prepare-aria2-runtime.mjs all",
    "build:server": "go build -o dist/aria2mx ./cmd/aria2mx",
    "build:allinone": "pnpm run build && pnpm run prepare:aria2 && go build -tags allinone -o dist/aria2mx ./cmd/aria2mx",
    "build:all": "pnpm run build && pnpm run build:server",
    "preview": "vite preview",
    "check": "vue-tsc -b",
    "lint": "eslint . --ext .ts,.vue",
    "lint:fix": "eslint . --ext .ts,.vue --fix"
  },
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "codemirror": "^6.0.2",
    "lucide-vue-next": "^0.511.0",
    "vue": "^3.4.15",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-vue": "^5.0.3",
    "@vue/runtime-dom": "^3.4.15",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.20.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "vite": "^5.0.12",
    "vue-tsc": "^1.8.27"
  }
}
